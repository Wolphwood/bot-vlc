{
  "name": "Venture - Tutoriel de jeu",
  "authors": [
    {
      "name": "Wolphwood",
      "contact": {
        "bsky": "wolphwood.bsky.social",
        "twitter": "wolphwood",
        "website": "https://wolphwood.ovh"
      }
    }
  ],
  "version": "1",
  "tags": ["tutorial", "game", "rpg"],
  "presentation": "Bienvenue dans le tutoriel de Venture ! Apprenez à interagir avec votre inventaire, gérer vos statistiques et comprendre les mécaniques de choix.",
  "rewards": [
    {
      "id": "golden_medal",
      "title": "Médaille d'or",
      "description": "Une médaille brillante pour honorer vos exploits.",
      "image": {
        "url": "https://assets.goldavenue.com/uploads/tag/og_image/2253/AdobeStock_784413881__1_.jpeg"
      },
      "color": "#FFD700"
    }
  ],
  "initialization": {
    "situation": "intro_situation",
    "stats": {
      "health": 0
    },
    "inventory": {
      "sword": 0,
      "apple": {
        "min": 0,
        "max": 2,
        "precision": 4,
        "round": "round"
      },
      "pear": 0
    },
    "variables": {
      "value": 0
    }
  },
  "situations": [
    {
      "id": "intro_situation",
      "description": "Bienvenue dans votre aventure !\nSuivez ce tutoriel pour apprendre à jouer.",
      "options": [
        {
          "label": "Commencer le tutoriel",
          "details": "Ce bouton va t'emmener à la première étape de ce tutoriel",
          "actions": [
            {
              "type": "goto",
              "target": "inventory_tutorial"
            },
            {
              "type": "reward",
              "id": "golden_medal"
            }
          ]
        }
      ]
    },
    {
      "id": "inventory_tutorial",
      "description": "Vous êtes dans une pièce avec une épée posée sur la table.\nApprenez à ajouter des objets à votre inventaire.",
      "options": [
        {
          "label": "Prendre l'épée",
          "requirements": [
            {
              "type": "comparison",
              "left": "inventory.sword",
              "operator": "<",
              "right": 1
            }
          ],
          "actions": [
            {
              "type": "inventory",
              "item": "sword",
              "count": 1,
              "action": "add"
            }
          ]
        },
        {
          "label": "Continuer",
          "requirements": [
            {
              "type": "comparison",
              "left": "inventory.sword",
              "operator": ">=",
              "right": 1
            }
          ],
          "actions": [
            {
              "type": "goto",
              "target": "stats_tutorial"
            }
          ]
        }
      ]
    },
    {
      "id": "stats_tutorial",
      "description": "Maintenant que vous avez votre épée, apprenez à gérer vos statistiques. Votre santé est de %stats.health%.\nSi votre santé tombe à zéro, vous perdez la partie.",
      "options": [
        {
          "label": "Vérifier vos statistiques",
          "requirements": [
            {
              "type": "comparison",
              "left": "stats.health",
              "operator": "<",
              "right": 1
            }
          ],
          "actions": [
            {
              "type": "stat",
              "name": "health",
              "value": 10,
              "operator": "add"
            }
          ]
        },
        {
          "label": "Continuer",
          "requirements": [
            {
              "type": "comparison",
              "left": "stats.health",
              "operator": ">",
              "right": 0
            }
          ],
          "actions": [
            {
              "type": "goto",
              "target": "condition_tutorial"
            }
          ]
        }
      ]
    },
    {
      "id": "condition_tutorial",
      "description": "Parfois, vous devrez prendre des décisions en fonction de vos statistiques.\nPar exemple, si votre santé tombe sous 50, vous devrez vous soigner.\nPour continuer, votre vie doit être supérieure ou égale à 50, votre santé actuellement est de %stats.health%",
      "options": [
        {
          "label": "Vérifier la santé",
          "actions": [
            {
              "type": "condition",
              "requirements": [
                {
                  "type": "comparison",
                  "left": "stats.health",
                  "operator": ">=",
                  "right": 50
                }
              ],
              "success": [
                {
                  "type": "goto",
                  "target": "combat_tutorial"
                }
              ],
              "fail": [
                {
                  "type": "inventory",
                  "item": "potion",
                  "count": 1,
                  "action": "add"
                },
                {
                  "type": "stat",
                  "name": "health",
                  "value": 10,
                  "operator": "add"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "combat_tutorial",
      "description": "Vous êtes confronté à un ennemi. Utilisez l'épée que vous avez ramassée pour l'attaquer.\nPour battre l'énnemie vous devez faire 0.95, votre score actuel est 0.%variables.value%",
      "options": [
        {
          "label": "Attaquer l'ennemi",
          "requirements": [
            {
              "type": "comparison",
              "left": "variables.value",
              "operator": "!=",
              "right": "95"
            }
          ],
          "actions": [
            {
              "type": "variable",
              "name": "value",
              "value": { "min": 90, "max": 100, "round": "round" },
              "operator": "set"
            }
          ]
        },
        {
          "label": "Continuez",
          "requirements": [
            {
              "type": "comparison",
              "left": "variables.value",
              "operator": "==",
              "right": "95"
            }
          ],
          "actions": [
            {
              "type": "goto",
              "target": "end_tutorial"
            }
          ]
        }
      ]
    },
    {
      "id": "end_tutorial",
      "description": "Félicitations !\nVous avez terminé le tutoriel et êtes maintenant prêt à commencer votre aventure.",
      "options": [
        {
          "label": "Terminerle tutoriel",
          "actions": [
            {
              "type": "reward",
              "id": "golden_medal" 
            },
            {
              "type": "end"
            }
          ]
        }
      ]
    }
  ]
}
